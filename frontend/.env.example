# Public API base URL compiled into the static GitHub Pages build.
# GitHub Pages is HTTPS, so this should also be HTTPS.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Leave blank for a user/organization Pages site at https://<user>.github.io/.
# Set to /<repo-name> for a project Pages site at https://<user>.github.io/<repo-name>/.
NEXT_PUBLIC_BASE_PATH=
