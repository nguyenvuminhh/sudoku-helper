# Backend runtime settings for EC2/Docker.
PORT=8000

# Comma-separated frontend origins allowed to call the API.
# Use your GitHub Pages URL and any custom frontend domain.
PUZZLE_HINT_CORS_ORIGINS=https://<github-user>.github.io,https://<github-user>.github.io/<repo-name>

# Empty disables FastAPI static frontend serving for API-only deployment.
PUZZLE_HINT_STATIC_DIR=

# Optional ONNX digit model path inside the container/host.
# SUDOKU_DIGIT_MODEL=/app/data/models/onnx-mnist/mnist-8.onnx
